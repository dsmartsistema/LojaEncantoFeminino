rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: categories
    // Fields:
    //   - name: string (required)
    //   - slug: string (required)
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - categoryId: string (required)
    //   - mainImage: string (required)
    //   - gallery: list of strings
    //   - sizes: list of strings
    //   - slug: string (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "eeicincosentidos@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Rules for Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Upload Sessions (Mobile to Desktop sync)
    match /upload_sessions/{sessionId} {
      allow read, write: if true;
      
      match /images/{imageId} {
        allow read, write: if true;
      }
    }

    // Rules for Users (Admin roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
